# Copy this file to .env and fill in real values before starting the server.

# Port the dashboard runs on
PORT=3000

# Public base URL of this server (NEEDED for open-tracking to work).
# Gmail loads the tracking pixel from this URL when someone opens the mail,
# so it must be reachable from the internet (a real domain, or an ngrok/tunnel
# URL while testing). http://localhost:3000 will NOT work for real tracking.
BASE_URL=http://localhost:3000

# 32-byte hex key used to encrypt Gmail app passwords before they are saved
# to disk. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_characters
